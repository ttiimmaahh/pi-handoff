{
  "name": "@ttiimmaahh/pi-handoff",
  "version": "0.1.1",
  "description": "Proactive context-handoff for the pi coding agent: at a context-usage threshold, auto-write a structured session handoff doc and offer to reload it in a new session.",
  "license": "MIT",
  "author": "Tim Pearson (https://github.com/ttiimmaahh)",
  "homepage": "https://github.com/ttiimmaahh/pi-handoff#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ttiimmaahh/pi-handoff.git"
  },
  "bugs": {
    "url": "https://github.com/ttiimmaahh/pi-handoff/issues"
  },
  "type": "module",
  "keywords": [
    "pi-package",
    "pi-extension",
    "pi",
    "handoff",
    "context",
    "compaction",
    "coding-agent"
  ],
  "files": [
    "index.ts",
    "src",
    "scripts",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "tsconfig.json"
  ],
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "scripts": {
    "test": "node scripts/test-custom-provider-completion.mjs",
    "typecheck": "tsc --noEmit",
    "pack:dry-run": "npm pack --dry-run",
    "prepublishOnly": "npm run typecheck && npm test"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": ">=0.80.9 <0.81",
    "@earendil-works/pi-coding-agent": ">=0.80.9 <0.81"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "^0.80.10",
    "@earendil-works/pi-coding-agent": "^0.80.10",
    "typescript": "^7.0.2"
  },
  "engines": {
    "node": ">=22.19.0"
  }
}
